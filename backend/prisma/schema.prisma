// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum ActivityType {
  LOGIN
  LOGOUT
  MEMORY_CREATED
  MEMORY_UPDATED
  MEMORY_DELETED
  ALBUM_CREATED
  ALBUM_UPDATED
  ALBUM_DELETED
}


model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  emailVerified Boolean @default(false)
  fullName  String?
  bio       String?
  location  String?
  avatarUrl String?
  avatarPublicId String?
  memories  Memory[]
  albums    Album[]
  tags      Tag[]
  notifications Notification[]
  notificationPreference NotificationPreference?
  privacyPreference PrivacyPreference?
  activities Activity[]
  emailVerifications EmailVerification[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PrivacyPreference {
  id                  String   @id @default(uuid())
  userId              String   @unique
  confirmBeforeDelete Boolean  @default(true)
  allowAiSearch       Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationPreference {
  id                     String   @id @default(uuid())
  userId                 String   @unique
  notifyMemoryActivity   Boolean  @default(true)
  notifyAlbumActivity    Boolean  @default(true)
  notifyFavoriteActivity Boolean  @default(true)
  notifyAiSearch         Boolean  @default(true)
  notifyMemoryReminders  Boolean  @default(true)
  notifyOnThisDay        Boolean  @default(true)
  notifyStorageAlerts    Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  type      String
  pendingEmail String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum MediaType {
  IMAGE
  VIDEO
}


model Memory {
  id          String   @id @default(uuid())
  title       String
  description String?
  mediaUrl    String?
  mediaPublicId String?
  mediaType MediaType? @default(IMAGE)
  tags        Tag[]
  memoryDate  DateTime?
  location    String?
  isFavorite  Boolean  @default(false)
  isArchived  Boolean  @default(false)

  albumId String?

  album Album? @relation(fields: [albumId], references: [id], onDelete: SetNull)

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Album {
  id          String   @id @default(uuid())
  name        String
  description String?
  coverUrl    String?
  coverPublicId String?

  memories Memory[]

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tag {
  id        String   @id @default(uuid())
  name      String
  color     String?
  memories  Memory[]

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  title       String
  message     String
  category    String   @default("Account")
  type        NotificationType @default(INFO)
  icon        String?
  isRead      Boolean  @default(false)
  actionType  String?
  actionId    String?
  groupKey    String?
  groupCount  Int      @default(1)

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Activity {
  id        String   @id @default(uuid())
  action    String
  message   String
  type      ActivityType?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
